# --- LLM provider ---
# "gemini" (free tier) | "anthropic" (paid, ~cents/interview) | "mock" | "auto"
LLM_PROVIDER=anthropic

# Gemini — free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Anthropic / Claude — https://console.anthropic.com (no free tier)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Optional: a GitHub token raises the public API rate limit (60 -> 5000 req/hr).
GITHUB_TOKEN=

# SQLite database URL
DATABASE_URL=sqlite:///./ai_interviewer.db

# CORS origins for the frontend dev server (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Admin auth (dashboard) — CHANGE THESE ---
ADMIN_PASSWORD=changeme
ADMIN_SECRET=dev-admin-secret-change-me
