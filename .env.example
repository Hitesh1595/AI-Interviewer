# Root env used by docker compose.

# LLM provider: "anthropic" (Claude, paid) | "gemini" (free tier) | "mock" | "auto"
LLM_PROVIDER=anthropic

# Anthropic / Claude — https://console.anthropic.com  (no free tier)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Gemini — free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional: raises GitHub API rate limits.
GITHUB_TOKEN=

# Admin dashboard login — CHANGE THESE
ADMIN_PASSWORD=changeme
ADMIN_SECRET=dev-admin-secret-change-me
