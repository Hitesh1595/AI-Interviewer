# Root env used by docker compose. Runs entirely on OpenAI.

LLM_PROVIDER=openai

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_VOICE=alloy

# Optional: raises GitHub API rate limits.
GITHUB_TOKEN=

# Admin dashboard login — CHANGE THESE
ADMIN_PASSWORD=changeme
ADMIN_SECRET=dev-admin-secret-change-me
